{
  "name": "RoadmapTask",
  "type": "object",
  "properties": {
    "student_user_id": {
      "type": "string",
      "description": "학생 User id"
    },
    "month": {
      "type": "string",
      "description": "YYYY-MM 형식의 준비 월"
    },
    "title": {
      "type": "string",
      "description": "할 일 제목"
    },
    "description": {
      "type": "string",
      "description": "할 일 설명"
    },
    "status": {
      "type": "string",
      "enum": ["예정", "진행중", "완료", "긴급"],
      "default": "예정",
      "description": "진행 상태"
    },
    "due_date": {
      "type": "string",
      "format": "date",
      "description": "마감일"
    }
  },
  "required": ["month", "title", "status"]
}
